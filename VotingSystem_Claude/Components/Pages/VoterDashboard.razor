@page "/voter-dashboard"
@using VotingSystem_Claude.Models
@using VotingSystem_Claude.Services.Interfaces
@inject IAuthService AuthService
@inject IElectionService ElectionService
@inject IVotingService VotingService
@inject NavigationManager NavigationManager

<div class="container mt-5">
    @if (_loading)
    {
        <div class="spinner-border text-primary" role="status">
            <span class="visually-hidden">Loading...</span>
        </div>
    }
    else if (_voter != null)
    {
        <div class="alert alert-success mb-4">
            <h4>Welcome, @_voter.Student?.FullName</h4>
            <p>Class: @_voter.Student?.Class</p>
        </div>
        @if (_activeElection != null)
        {
            <div class="card mb-4">
                <div class="card-header bg-primary text-white">
                    <h3 class="mb-0">@_activeElection.Title</h3>
                </div>
                <div class="card-body">
                    <p class="lead">@_activeElection.Description</p>
                    <p><strong>Voting Period:</strong> @_activeElection.StartDate.ToString("MMM dd, yyyy") - @_activeElection.EndDate.ToString("MMM dd, yyyy")</p>
                    @if (_hasVoted)
                    {
                        <div class="alert alert-info">
                            <i class="bi bi-check-circle-fill me-2"></i>You have already cast your vote in this election.
                        </div>
                        <button class="btn btn-outline-primary" @onclick="ViewResults">
                            <i class="bi bi-bar-chart-fill me-2"></i>View Results
                        </button>
                    }
                    else
                    {
                        <button class="btn btn-primary btn-lg" @onclick="StartVoting">
                            <i class="bi bi-box-arrow-in-right me-2"></i>Start Voting
                        </button>
                    }
                </div>
            </div>
        }
        else
        {
            <div class="alert alert-info mb-4">
                <h4>No Active Elections</h4>
                <p>There are no active elections at the moment. Please check back later.</p>
            </div>
        }
        <button class="btn btn-outline-danger" @onclick="Logout">
            <i class="bi bi-box-arrow-right me-2"></i>Logout
        </button>
    }
    else
    {
        <div class="alert alert-danger">You are not logged in as a voter.</div>
    }
</div>

@code {
    private bool _loading = true;
    private VotingSystem_Claude.Models.Voter? _voter;
    private Election? _activeElection;
    private bool _hasVoted;

    protected override async Task OnInitializedAsync()
    {
        _voter = await AuthService.GetAuthenticatedVoterAsync();
        if (_voter != null)
        {
            _activeElection = await ElectionService.GetActiveElectionAsync();
            if (_activeElection != null)
            {
                _hasVoted = await VotingService.HasVotedInElectionAsync(_voter.Id, _activeElection.Id);
            }
        }
        _loading = false;
    }

    private void StartVoting()
    {
        if (_activeElection != null)
        {
            NavigationManager.NavigateTo($"/voting/{_activeElection.Id}");
        }
    }

    private void ViewResults()
    {
        if (_activeElection != null)
        {
            Console.WriteLine($"Navigating to results for Election ID: {_activeElection.Id}");
            NavigationManager.NavigateTo($"/results/{_activeElection.Id}");
        }
        else
        {
            Console.WriteLine("Attempted to navigate to results, but no active election found.");
        }
    }

    private async Task Logout()
    {
        await AuthService.LogoutAsync();
        NavigationManager.NavigateTo("/");
    }
} 