@page "/admin-dashboard"
@using VotingSystem_Claude.Models
@using VotingSystem_Claude.Services
@using VotingSystem_Claude.Services.Interfaces
@inject IAuthService AuthService
@inject IResultsService ResultsService
@inject IVoterService VoterService
@inject IElectionService ElectionService
@inject ICandidateService CandidateService
@inject NavigationManager NavigationManager
@inject IJSRuntime JSRuntime

<PageTitle>Admin Dashboard - School Voting System</PageTitle>

@if (_loading)
{
    <div class="container mt-5">
        <div class="row justify-content-center">
            <div class="col-md-6">
                <div class="text-center">
                    <div class="spinner-border text-primary" role="status">
                        <span class="visually-hidden">Loading...</span>
                    </div>
                    <p class="mt-2">Verifying access...</p>
                </div>
            </div>
        </div>
    </div>
}
else if (!_isAuthenticated)
{
    <div class="container mt-5">
        <div class="row justify-content-center">
            <div class="col-md-6">
                <div class="alert alert-danger">
                    <h4>Access Denied</h4>
                    <p>You must be logged in as an administrator to access this page.</p>
                    <button class="btn btn-primary" @onclick="GoToHome">Go to Login</button>
                </div>
            </div>
        </div>
    </div>
}
else
{
    <div class="container-fluid mt-4">
        <div class="row mb-4">
            <div class="col-12">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <h1 class="h2 mb-0">
                            <i class="bi bi-speedometer2 me-2"></i>
                            Administrator Dashboard
                        </h1>
                        <p class="text-muted mb-0">Manage your school voting system</p>
                    </div>
                    <div>
                        <button class="btn btn-outline-primary me-2" @onclick="RefreshData">
                            <i class="bi bi-arrow-clockwise me-1"></i>
                            Refresh
                        </button>
                        <button class="btn btn-outline-danger" @onclick="Logout">
                            <i class="bi bi-box-arrow-right me-1"></i>
                            Logout
                        </button>
                    </div>
                </div>
            </div>
        </div>

        @if (_dataLoading)
        {
            <div class="text-center py-3">
                <div class="spinner-border spinner-border-sm text-primary" role="status">
                    <span class="visually-hidden">Loading...</span>
                </div>
                <span class="ms-2">Loading dashboard data...</span>
            </div>
        }

        <div class="row mb-4">
                <div class="col-lg-3 col-md-6 mb-3">
                    <div class="card border-0 shadow-sm h-100">
                        <div class="card-body">
                            <div class="d-flex align-items-center">
                                <div class="flex-shrink-0">
                                    <div class="bg-primary bg-opacity-10 rounded-3 p-3">
                                        <i class="bi bi-calendar-event text-primary fs-4"></i>
                                    </div>
                                </div>
                                <div class="flex-grow-1 ms-3">
                                    <h6 class="text-muted mb-1">Total Elections</h6>
                                    <h3 class="mb-0">@_totalElections</h3>
                                    @if (_activeElection != null)
                                    {
                                        <small class="text-success">
                                            <i class="bi bi-dot"></i>
                                            1 Active
                                        </small>
                                    }
                                    else
                                    {
                                        <small class="text-muted">
                                            <i class="bi bi-dot"></i>
                                            None Active
                                        </small>
                                    }
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="col-lg-3 col-md-6 mb-3">
                    <div class="card border-0 shadow-sm h-100">
                        <div class="card-body">
                            <div class="d-flex align-items-center">
                                <div class="flex-shrink-0">
                                    <div class="bg-success bg-opacity-10 rounded-3 p-3">
                                        <i class="bi bi-people text-success fs-4"></i>
                                    </div>
                                </div>
                                <div class="flex-grow-1 ms-3">
                                    <h6 class="text-muted mb-1">Registered Voters</h6>
                                    <h3 class="mb-0">@_totalVoters</h3>
                                    @if (_activeElection != null)
                                    {
                                        <small class="text-info">
                                            <i class="bi bi-dot"></i>
                                            @_votersWhoVoted voted
                                        </small>
                                    }
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="col-lg-3 col-md-6 mb-3">
                    <div class="card border-0 shadow-sm h-100">
                        <div class="card-body">
                            <div class="d-flex align-items-center">
                                <div class="flex-shrink-0">
                                    <div class="bg-info bg-opacity-10 rounded-3 p-3">
                                        <i class="bi bi-person-badge text-info fs-4"></i>
                                    </div>
                                </div>
                                <div class="flex-grow-1 ms-3">
                                    <h6 class="text-muted mb-1">Total Candidates</h6>
                                    <h3 class="mb-0">@_totalCandidates</h3>
                                    @if (_activeElection != null)
                                    {
                                        <small class="text-muted">
                                            <i class="bi bi-dot"></i>
                                            Active Election
                                        </small>
                                    }
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="col-lg-3 col-md-6 mb-3">
                    <div class="card border-0 shadow-sm h-100">
                        <div class="card-body">
                            <div class="d-flex align-items-center">
                                <div class="flex-shrink-0">
                                    <div class="bg-warning bg-opacity-10 rounded-3 p-3">
                                        <i class="bi bi-percent text-warning fs-4"></i>
                                    </div>
                                </div>
                                <div class="flex-grow-1 ms-3">
                                    <h6 class="text-muted mb-1">Voter Turnout</h6>
                                    <h3 class="mb-0">@(_voterTurnoutPercentage.ToString("F1"))%</h3>
                                    @if (_activeElection != null)
                                    {
                                        <small class="text-muted">
                                            <i class="bi bi-dot"></i>
                                            Current Election
                                        </small>
                                    }
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            @if (_activeElection != null)
            {
                <div class="row mb-4">
                    <div class="col-12">
                        <div class="card border-0 shadow-sm">
                            <div class="card-header bg-primary text-white">
                                <h5 class="mb-0">
                                    <i class="bi bi-calendar-check me-2"></i>
                                    Active Election: @_activeElection.Title
                                </h5>
                            </div>
                            <div class="card-body">
                                <div class="row">
                                    <div class="col-md-8">
                                        <p class="mb-2"><strong>Description:</strong> @_activeElection.Description</p>
                                        <p class="mb-2">
                                            <strong>Period:</strong> 
                                            @_activeElection.StartDate.ToString("MMM dd, yyyy HH:mm") - 
                                            @_activeElection.EndDate.ToString("MMM dd, yyyy HH:mm")
                                        </p>
                                        <p class="mb-0">
                                            <strong>School Year:</strong> @_activeElection.SchoolYear
                                        </p>
                                    </div>
                                    <div class="col-md-4 text-end">
                                        <div class="d-grid gap-2">
                                            <button class="btn btn-outline-primary" @onclick="() => ViewElectionResults(_activeElection.Id)">
                                                <i class="bi bi-bar-chart me-1"></i>
                                                View Results
                                            </button>
                                            <button class="btn btn-outline-info" @onclick="() => ManageElection(_activeElection.Id)">
                                                <i class="bi bi-gear me-1"></i>
                                                Manage
                                            </button>
                                        </div>
                                    </div>
                                </div>

                                @if (_activeElection.Positions != null && _activeElection.Positions.Any())
                                {
                                    <hr />
                                    <h6 class="text-muted mb-3">Positions (@_activeElection.Positions.Count())</h6>
                                    <div class="row g-2">
                                        @foreach (var position in _activeElection.Positions.OrderBy(p => p.DisplayOrder))
                                        {
                                            <div class="col-md-6 col-lg-4">
                                                <div class="bg-light rounded p-2">
                                                    <small class="fw-semibold">@position.Title</small>
                                                    <br />
                                                    <small class="text-muted">
                                                        @(position.Candidates?.Count() ?? 0) candidates
                                                    </small>
                                                </div>
                                            </div>
                                        }
                                    </div>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            }

            <div class="row mb-4">
                <div class="col-12">
                    <div class="card border-0 shadow-sm">
                        <div class="card-header">
                            <h5 class="mb-0">
                                <i class="bi bi-lightning me-2"></i>
                                Quick Actions
                            </h5>
                        </div>
                        <div class="card-body">
                            <div class="row g-3">
                                <div class="col-md-6 col-lg-3">
                                    <button class="btn btn-outline-primary w-100 h-100 d-flex flex-column align-items-center justify-content-center p-4" 
                                            @onclick="NavigateToElections">
                                        <i class="bi bi-calendar-plus fs-1 mb-2"></i>
                                        <span class="fw-semibold">Create Election</span>
                                        <small class="text-muted">Set up new voting</small>
                                    </button>
                                </div>
                                <div class="col-md-6 col-lg-3">
                                    <button class="btn btn-outline-success w-100 h-100 d-flex flex-column align-items-center justify-content-center p-4" 
                                            @onclick="NavigateToVoterCodes">
                                        <i class="bi bi-qr-code fs-1 mb-2"></i>
                                        <span class="fw-semibold">Manage Codes</span>
                                        <small class="text-muted">Generate voter codes</small>
                                    </button>
                                </div>
                                <div class="col-md-6 col-lg-3">
                                    <button class="btn btn-outline-info w-100 h-100 d-flex flex-column align-items-center justify-content-center p-4" 
                                            @onclick="NavigateToResults">
                                        <i class="bi bi-graph-up fs-1 mb-2"></i>
                                        <span class="fw-semibold">View Results</span>
                                        <small class="text-muted">Election analytics</small>
                                    </button>
                                </div>
                                <div class="col-md-6 col-lg-3">
                                    <button class="btn btn-outline-warning w-100 h-100 d-flex flex-column align-items-center justify-content-center p-4" 
                                            @onclick="NavigateToStudents">
                                        <i class="bi bi-people-fill fs-1 mb-2"></i>
                                        <span class="fw-semibold">Manage Students</span>
                                        <small class="text-muted">Student database</small>
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="row">
                <div class="col-md-6">
                    <div class="card border-0 shadow-sm">
                        <div class="card-header">
                            <h6 class="mb-0">
                                <i class="bi bi-clock-history me-2"></i>
                                Recent Elections
                            </h6>
                        </div>
                        <div class="card-body">
                            @if (_recentElections.Any())
                            {
                                @foreach (var election in _recentElections.Take(5))
                                {
                                    <div class="d-flex align-items-center mb-3">
                                        <div class="flex-shrink-0">
                                            @if (election.IsActive)
                                            {
                                                <span class="badge bg-success">Active</span>
                                            }
                                            else if (election.EndDate < DateTime.UtcNow)
                                            {
                                                <span class="badge bg-secondary">Ended</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-warning">Upcoming</span>
                                            }
                                        </div>
                                        <div class="flex-grow-1 ms-3">
                                            <h6 class="mb-0">@election.Title</h6>
                                            <small class="text-muted">
                                                @election.StartDate.ToString("MMM dd, yyyy")
                                            </small>
                                        </div>
                                        <div class="flex-shrink-0">
                                            <button class="btn btn-sm btn-outline-primary" 
                                                    @onclick="() => ManageElection(election.Id)">
                                                <i class="bi bi-arrow-right"></i>
                                            </button>
                                        </div>
                                    </div>
                                }
                            }
                            else
                            {
                                <p class="text-muted mb-0">No elections found.</p>
                            }
                        </div>
                    </div>
                </div>

                <div class="col-md-6">
                    <div class="card border-0 shadow-sm">
                        <div class="card-header">
                            <h6 class="mb-0">
                                <i class="bi bi-info-circle me-2"></i>
                                System Status
                            </h6>
                        </div>
                        <div class="card-body">
                            <div class="row g-3">
                                <div class="col-12">
                                    <div class="d-flex justify-content-between align-items-center">
                                        <span>Database Connection</span>
                                        <span class="badge bg-success">Online</span>
                                    </div>
                                </div>
                                <div class="col-12">
                                    <div class="d-flex justify-content-between align-items-center">
                                        <span>Voting System</span>
                                        @if (_activeElection != null)
                                        {
                                            <span class="badge bg-success">Active</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary">Inactive</span>
                                        }
                                    </div>
                                </div>
                                <div class="col-12">
                                    <div class="d-flex justify-content-between align-items-center">
                                        <span>Last Update</span>
                                        <small class="text-muted">@DateTime.Now.ToString("HH:mm")</small>
                                    </div>
                                </div>
                                <div class="col-12">
                                    <div class="d-flex justify-content-between align-items-center">
                                        <span>Server Time</span>
                                        <small class="text-muted">@DateTime.UtcNow.ToString("yyyy-MM-dd HH:mm UTC")</small>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
    </div>
}

@code {
    private bool _isAuthenticated = false;
    private bool _loading = true;
    private bool _dataLoading = false;
    
    // Dashboard metrics
    private int _totalElections = 0;
    private int _totalVoters = 0;
    private int _totalCandidates = 0;
    private int _votersWhoVoted = 0;
    private double _voterTurnoutPercentage = 0;
    
    // Election data
    private Election _activeElection;
    private List<Election> _recentElections = new();

    protected override async Task OnInitializedAsync()
    {
        _isAuthenticated = await AuthService.IsAdminAsync();
        
        if (_isAuthenticated)
        {
            await LoadDashboardData();
        }
        
        _loading = false;
    }

    private async Task LoadDashboardData()
    {
        _dataLoading = true;
        _totalElections = (await ElectionService.GetAllElectionsAsync()).Count();
        _totalVoters = (await VoterService.GetAllVotersAsync()).Count();
        _totalCandidates = (await CandidateService.GetAllCandidatesAsync()).Count();
        _activeElection = await ElectionService.GetActiveElectionAsync();

        if (_activeElection != null)
        {
            _votersWhoVoted = await ResultsService.GetTotalVotersAsync(_activeElection.Id);
            if (_totalVoters > 0)
            {
                _voterTurnoutPercentage = (_votersWhoVoted * 100.0 / _totalVoters);
            }
            else
            {
                _voterTurnoutPercentage = 0.0;
            }
        }
        else
        {
            _votersWhoVoted = 0;
            _voterTurnoutPercentage = 0.0;
        }

        _recentElections = (await ElectionService.GetAllElectionsAsync())
            .Where(e => e.Id != _activeElection?.Id)
            .OrderByDescending(e => e.StartDate)
            .Take(5)
            .ToList();

        _dataLoading = false;
    }

    private async Task RefreshData()
    {
        _dataLoading = true;
        StateHasChanged();
        
        await LoadDashboardData();
        
        _dataLoading = false;
        StateHasChanged();
    }

    private async Task Logout()
    {
        await AuthService.LogoutAsync();
        NavigationManager.NavigateTo("/");
    }

    private void GoToHome()
    {
        NavigationManager.NavigateTo("/");
    }

    // Navigation methods
    private void NavigateToElections()
    {
        NavigationManager.NavigateTo("/elections");
    }

    private void NavigateToVoterCodes()
    {
        NavigationManager.NavigateTo("/votercodes");
    }

    private void NavigateToResults()
    {
        NavigationManager.NavigateTo("/results");
    }

    private void NavigateToStudents()
    {
        NavigationManager.NavigateTo("/students");
    }

    private void ManageElection(int electionId)
    {
        NavigationManager.NavigateTo($"/elections/{electionId}");
    }

    private void ViewElectionResults(int electionId)
    {
        NavigationManager.NavigateTo($"/results/{electionId}");
    }
}