@page "/voting/{ElectionId:int}"
@using VotingSystem_Claude.Services
@using VotingSystem_Claude.Services.Interfaces
@using VotingSystem_Claude.Models
@using Microsoft.AspNetCore.Components
@using Microsoft.JSInterop
@implements IDisposable
@inject IElectionService ElectionService
@inject IVotingService VotingService
@inject IAuthService AuthService
@inject IRetryService RetryService
@inject IConnectivityService ConnectivityService
@inject NavigationManager NavigationManager
@inject IJSRuntime JSRuntime

<div class="container mt-4">
    @if (_loading)
    {
        <LoadingSpinner Show="true" 
                      Message="Loading election data..." 
                      SubMessage="Please wait while we prepare your ballot"
                      LoadingType="skeleton" 
                      ShowBackground="true" />
    }
    else if (_voter == null)
    {
        <div class="alert alert-danger">
            <h4>Access Denied</h4>
            <p>You must be logged in to vote.</p>
            <button class="btn btn-primary" @onclick="GoHome">Go to Login</button>
        </div>
    }
    else if (_election == null)
    {
        <div class="alert alert-warning">
            <h4>Election Not Found</h4>
            <p>The requested election could not be found or is not active.</p>
            <button class="btn btn-primary" @onclick="GoHome">Go Home</button>
        </div>
    }
    else if (_hasAlreadyVoted)
    {
        <div class="alert alert-info">
            <h4>Already Voted</h4>
            <p>You have already cast your vote in this election.</p>
            <button class="btn btn-primary" @onclick="GoHome">Go Home</button>
        </div>
    }
    else
    {
        <div class="row">
            <!-- Election Details and Voting UI -->
            <div class="col-md-8">
                <div class="card">
                    <div class="card-header bg-primary text-white">
                        <h3>@_election.Title</h3>
                        <p class="mb-2">@_election.Description</p>
                        
                        <!-- Progress Indicator -->
                        <div class="progress-container">
                            <div class="d-flex justify-content-between align-items-center mb-2">
                                <small>Voting Progress</small>
                                <small>@GetCompletedPositions() / @GetTotalPositions() positions completed</small>
                            </div>
                            <div class="progress" style="height: 8px;">
                                <div class="progress-bar bg-success" 
                                     role="progressbar" 
                                     style="width: @GetProgressPercentage()%" 
                                     aria-valuenow="@GetCompletedPositions()" 
                                     aria-valuemin="0" 
                                     aria-valuemax="@GetTotalPositions()">
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="card-body">
                        @if (!_isConnected)
                        {
                            <div class="alert alert-warning">
                                <i class="bi bi-wifi-off me-2"></i>
                                <strong>No Internet Connection</strong>
                                <p class="mb-2">Please check your network connection and try again.</p>
                                <button class="btn btn-sm btn-outline-primary" @onclick="CheckConnectivity">
                                    <i class="bi bi-arrow-clockwise me-1"></i>
                                    Retry Connection
                                </button>
                            </div>
                        }
                        
                        @if (!string.IsNullOrEmpty(_errorMessage))
                        {
                            <div class="alert alert-danger">
                                <i class="bi bi-exclamation-triangle me-2"></i>
                                @_errorMessage
                                @if (_canRetry)
                                {
                                    <br />
                                    <button class="btn btn-sm btn-outline-danger mt-2" @onclick="RetryLastOperation" disabled="@_retrying">
                                        @if (_retrying)
                                        {
                                            <span class="spinner-border spinner-border-sm me-1" role="status"></span>
                                        }
                                        <i class="bi bi-arrow-clockwise me-1"></i>
                                        Retry
                                    </button>
                                }
                            </div>
                        }

                        @if (_election.Positions?.Any() == true)
                        {
                            @foreach (var position in _election.Positions.OrderBy(p => p.DisplayOrder))
                            {
                                <div class="position-section mb-5">
                                    <h4 class="border-bottom pb-2 d-flex justify-content-between align-items-center">
                                        @position.Title
                                        @if (IsPositionCompleted(position.Id))
                                        {
                                            <span class="badge bg-success">
                                                <i class="bi bi-check-circle me-1"></i>
                                                Complete
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-warning">
                                                <i class="bi bi-clock me-1"></i>
                                                Pending
                                            </span>
                                        }
                                    </h4>

                                    @if (!string.IsNullOrEmpty(position.Description))
                                    {
                                        <p class="text-muted">@position.Description</p>
                                    }

                                    @if (position.MaxSelectableOptions > 1)
                                    {
                                        <div class="alert alert-info">
                                            <small>
                                                <i class="bi bi-info-circle me-1"></i>
                                                You can select up to <strong>@position.MaxSelectableOptions</strong> candidates for this position.
                                                @if (GetSelectedCount(position.Id) > 0)
                                                {
                                                    <span class="ms-2">
                                                        (@GetSelectedCount(position.Id) of @position.MaxSelectableOptions selected)
                                                    </span>
                                                }
                                            </small>
                                        </div>
                                    }

                                    @if (position.Candidates?.Any() == true)
                                    {
                                        <div class="row">
                                            @foreach (var candidate in position.Candidates)
                                            {
                                                <div class="col-md-6 mb-3">
                                                    <div class="card candidate-card @(IsSelected(position.Id, candidate.Id) ? "border-primary bg-light" : "")">
                                                        <div class="card-body">
                                                            <div class="d-flex align-items-center">
                                                                @if (position.MaxSelectableOptions == 1)
                                                                {
                                                                    <input type="radio"
                                                                           name="position_@position.Id"
                                                                           value="@candidate.Id"
                                                                           checked="@IsSelected(position.Id, candidate.Id)"
                                                                           @onchange="@(() => SelectCandidate(position.Id, candidate.Id))"
                                                                           class="form-check-input me-3" />
                                                                }
                                                                else
                                                                {
                                                                    <input type="checkbox"
                                                                           value="@candidate.Id"
                                                                           checked="@IsSelected(position.Id, candidate.Id)"
                                                                           @onchange="@((e) => ToggleCandidate(position.Id, candidate.Id, (bool)e.Value))"
                                                                           disabled="@(!IsSelected(position.Id, candidate.Id) && GetSelectedCount(position.Id) >= position.MaxSelectableOptions)"
                                                                           class="form-check-input me-3" />
                                                                }

                                                                <div class="flex-grow-1">
                                                                    @if (!string.IsNullOrEmpty(candidate.ImagePath))
                                                                    {
                                                                        <img src="@candidate.ImagePath"
                                                                             alt="@candidate.FullName"
                                                                             class="candidate-image rounded-circle me-3"
                                                                             style="width: 50px; height: 50px; object-fit: cover;" />
                                                                    }

                                                                    <div>
                                                                        <h6 class="mb-1">@candidate.FullName</h6>
                                                                        @if (!string.IsNullOrEmpty(candidate.Class))
                                                                        {
                                                                            <small class="text-muted">Class: @candidate.Class</small>
                                                                        }
                                                                        @if (!string.IsNullOrEmpty(candidate.ManifestoSummary))
                                                                        {
                                                                            <p class="small mt-2">@candidate.ManifestoSummary</p>
                                                                        }
                                                                    </div>
                                                                </div>
                                                            </div>
                                                        </div>
                                                    </div>
                                                </div>
                                            }
                                        </div>
                                    }
                                    else
                                    {
                                        <div class="alert alert-warning">No candidates available for this position.</div>
                                    }
                                </div>
                            }
                        }
                    </div>
                </div>
            </div>

            <!-- Summary Card -->
            <div class="col-md-4">
                <div class="card sticky-top">
                    <div class="card-header">
                        <h5>Voting Summary</h5>
                    </div>
                    <div class="card-body">
                        <div class="mb-3">
                            <strong>Voter:</strong> @_voter.Student.FullName<br />
                            <strong>Class:</strong> @_voter.Student.Class
                        </div>

                        <h6>Your Selections:</h6>
                        @if (_selectedCandidates.Any())
                        {
                            @foreach (var selection in _selectedCandidates)
                            {
                                var position = _election.Positions.FirstOrDefault(p => p.Id == selection.Key);
                                if (position != null)
                                {
                                    <div class="mb-2">
                                        <strong>@position.Title:</strong><br />
                                        @foreach (var candidateId in selection.Value)
                                        {
                                            var candidate = position.Candidates?.FirstOrDefault(c => c.Id == candidateId);
                                            if (candidate != null)
                                            {
                                                <small class="text-primary">• @candidate.FullName</small>
                        
                                                <br />
                                            }
                                        }
                                    </div>
                                }
                            }
                        }
                        else
                        {
                            <p class="text-muted">No selections made yet.</p>
                        }

                        <hr />
                        <div class="d-grid gap-2">
                            <button class="btn btn-success btn-lg"
                                    @onclick="ShowConfirmation"
                                    disabled="@(!CanSubmitVotes() || _submitting)">
                                @if (_submitting)
                                {
                                    <span class="spinner-border spinner-border-sm me-2" role="status"></span>
                                }
                                Submit Votes
                            </button>
                            <button class="btn btn-outline-secondary" @onclick="GoHome">Cancel</button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@code {
    [Parameter]
    public int ElectionId { get; set; }

    private Models.Voter _voter;
    private Election _election;
    private Dictionary<int, List<int>> _selectedCandidates = new();
    private bool _submitting;
    private string _errorMessage;
    private bool _loading = true;
    private bool _hasAlreadyVoted;
    private bool _showConfirmation = false;
    private bool _isConnected = true;
    private bool _canRetry = false;
    private bool _retrying = false;
    private Func<Task>? _lastFailedOperation;

    protected override async Task OnInitializedAsync()
    {
        // Subscribe to connectivity changes
        ConnectivityService.ConnectivityChanged += OnConnectivityChanged;
        
        try
        {
            _isConnected = await ConnectivityService.IsConnectedAsync();
            
            _voter = await AuthService.GetAuthenticatedVoterAsync();
            if (_voter == null)
            {
                NavigationManager.NavigateTo("/");
                return;
            }

            await LoadElectionDataWithRetry();
        }
        catch (Exception ex)
        {
            HandleError("An error occurred while loading the election data.", ex, () => LoadElectionDataWithRetry());
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task LoadElectionDataWithRetry()
    {
        await RetryService.ExecuteWithRetryAsync(async () =>
        {
            await LoadElectionData();
        });
    }

    private void OnConnectivityChanged(object? sender, bool isConnected)
    {
        InvokeAsync(() =>
        {
            _isConnected = isConnected;
            if (!isConnected)
            {
                _errorMessage = "";
                _canRetry = false;
            }
            StateHasChanged();
        });
    }

    private async Task LoadElectionData()
    {
        _election = await ElectionService.GetElectionByIdAsync(ElectionId);
        if (_election == null)
        {
            _errorMessage = "Election not found.";
            return;
        }

        if (!_election.IsActive || _election.StartDate > DateTime.UtcNow || _election.EndDate < DateTime.UtcNow)
        {
            _errorMessage = "This election is not currently active.";
            return;
        }

        if (await VotingService.HasVotedInElectionAsync(_voter.Id, ElectionId))
        {
            _errorMessage = "You have already voted in this election.";
            return;
        }

        // Initialize selected candidates dictionary
        foreach (var position in _election.Positions)
        {
            _selectedCandidates[position.Id] = new List<int>();
        }
    }

    private void SelectCandidate(int positionId, int candidateId)
    {
        _selectedCandidates[positionId] = new List<int> { candidateId };
    }

    private void ToggleCandidate(int positionId, int candidateId, bool isSelected)
    {
        if (!_selectedCandidates.ContainsKey(positionId))
        {
            _selectedCandidates[positionId] = new List<int>();
        }

        var position = _election.Positions.FirstOrDefault(p => p.Id == positionId);
        if (position == null) return;

        if (isSelected)
        {
            if (_selectedCandidates[positionId].Count < position.MaxSelectableOptions)
            {
                _selectedCandidates[positionId].Add(candidateId);
            }
        }
        else
        {
            _selectedCandidates[positionId].Remove(candidateId);
        }
    }

    private bool IsSelected(int positionId, int candidateId)
    {
        return _selectedCandidates.TryGetValue(positionId, out var selected) && selected.Contains(candidateId);
    }

    private bool CanSubmitVotes()
    {
        if (_election?.Positions == null) return false;

        // Check if all required positions have selections
        foreach (var position in _election.Positions)
        {
            if (!_selectedCandidates.ContainsKey(position.Id) || 
                !_selectedCandidates[position.Id].Any())
            {
                return false;
            }
        }

        return true;
    }

    private async Task SubmitVotes()
    {
        if (!CanSubmitVotes()) return;

        _submitting = true;
        _errorMessage = string.Empty;
        _canRetry = false;

        try
        {
            await RetryService.ExecuteWithRetryAsync(async () =>
            {
                // Check connectivity first
                if (!await ConnectivityService.IsConnectedAsync())
                {
                    throw new InvalidOperationException("No internet connection available.");
                }

                // Validate election is still active
                var currentElection = await ElectionService.GetElectionByIdAsync(ElectionId);
                if (currentElection == null || !currentElection.IsActive || 
                    currentElection.StartDate > DateTime.UtcNow || 
                    currentElection.EndDate < DateTime.UtcNow)
                {
                    throw new InvalidOperationException("This election is no longer active.");
                }

                // Validate voter hasn't voted in the meantime
                if (await VotingService.HasVotedInElectionAsync(_voter.Id, ElectionId))
                {
                    throw new InvalidOperationException("You have already voted in this election.");
                }

                var votes = _selectedCandidates
                    .Where(s => s.Value.Any())
                    .ToDictionary(s => s.Key, s => s.Value.First());

                var success = await VotingService.SubmitVotesAsync(_voter.Id, votes, ElectionId);

                if (!success)
                {
                    throw new InvalidOperationException("Failed to submit votes to the server.");
                }
            });

            // If we get here, submission was successful
            await JSRuntime.InvokeVoidAsync("alert", "Your votes have been submitted successfully!");
            NavigationManager.NavigateTo("/");
        }
        catch (InvalidOperationException ex)
        {
            // These are business logic errors that shouldn't be retried
            _errorMessage = ex.Message;
            _canRetry = false;
        }
        catch (Exception ex)
        {
            // These are technical errors that can be retried
            HandleError("Failed to submit your votes. This may be due to a temporary network issue.", ex, SubmitVotes);
        }
        finally
        {
            _submitting = false;
        }
    }

    private void GoHome()
    {
        NavigationManager.NavigateTo("/");
    }

    private void ShowConfirmation()
    {
        // Perform client-side validation before showing confirmation
        if (ValidateSelections(out var validationErrors))
        {
            _showConfirmation = true;
            _errorMessage = string.Empty; // Clear any previous errors
        }
        else
        {
            _errorMessage = string.Join(" ", validationErrors);
            _canRetry = false;
        }
    }

    private void HideConfirmation()
    {
        _showConfirmation = false;
    }

    private async Task ConfirmSubmitVotes()
    {
        _showConfirmation = false;
        await SubmitVotes();
    }

    private int GetCompletedPositions()
    {
        if (_election?.Positions == null) return 0;
        return _election.Positions.Count(p => IsPositionCompleted(p.Id));
    }

    private int GetTotalPositions()
    {
        return _election?.Positions?.Count ?? 0;
    }

    private double GetProgressPercentage()
    {
        var total = GetTotalPositions();
        if (total == 0) return 0;
        return (GetCompletedPositions() / (double)total) * 100;
    }

    private bool IsPositionCompleted(int positionId)
    {
        return _selectedCandidates.ContainsKey(positionId) && _selectedCandidates[positionId].Any();
    }

    private int GetSelectedCount(int positionId)
    {
        return _selectedCandidates.ContainsKey(positionId) ? _selectedCandidates[positionId].Count : 0;
    }

    private bool ValidateSelections(out List<string> validationErrors)
    {
        validationErrors = new List<string>();

        if (_election?.Positions == null)
        {
            validationErrors.Add("No positions found in this election.");
            return false;
        }

        foreach (var position in _election.Positions)
        {
            var selectedCount = GetSelectedCount(position.Id);
            
            if (selectedCount == 0)
            {
                validationErrors.Add($"Please make a selection for {position.Title}.");
            }
            else if (selectedCount > position.MaxSelectableOptions)
            {
                validationErrors.Add($"Too many selections for {position.Title}. Maximum allowed: {position.MaxSelectableOptions}.");
            }
        }

        return !validationErrors.Any();
    }

    private void HandleError(string userMessage, Exception ex, Func<Task>? retryOperation = null)
    {
        _errorMessage = userMessage;
        _canRetry = retryOperation != null;
        _lastFailedOperation = retryOperation;
        
        Console.WriteLine($"Error: {ex.Message}");
        if (ex.InnerException != null)
        {
            Console.WriteLine($"Inner Exception: {ex.InnerException.Message}");
        }
    }

    private async Task RetryLastOperation()
    {
        if (_lastFailedOperation == null) return;

        _retrying = true;
        _errorMessage = string.Empty;
        
        try
        {
            await _lastFailedOperation();
            _canRetry = false;
            _lastFailedOperation = null;
        }
        catch (Exception ex)
        {
            HandleError("Retry failed. Please check your connection and try again.", ex, _lastFailedOperation);
        }
        finally
        {
            _retrying = false;
        }
    }

    private async Task CheckConnectivity()
    {
        _isConnected = await ConnectivityService.IsConnectedAsync();
        StateHasChanged();
    }

    public void Dispose()
    {
        ConnectivityService.ConnectivityChanged -= OnConnectivityChanged;
    }
}

@if (_showConfirmation)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header bg-warning">
                    <h5 class="modal-title">
                        <i class="bi bi-exclamation-triangle me-2"></i>
                        Confirm Your Votes
                    </h5>
                </div>
                <div class="modal-body">
                    <div class="alert alert-warning">
                        <strong>Important:</strong> Once you submit your votes, you cannot change them. Please review your selections carefully.
                    </div>
                    
                    <h6 class="mb-3">Your Voting Summary:</h6>
                    <div class="card">
                        <div class="card-body">
                            <p><strong>Voter:</strong> @_voter?.Student?.FullName</p>
                            <p><strong>Class:</strong> @_voter?.Student?.Class</p>
                            <p><strong>Election:</strong> @_election?.Title</p>
                            
                            <hr />
                            
                            <h6>Selected Candidates:</h6>
                            @foreach (var selection in _selectedCandidates.Where(s => s.Value.Any()))
                            {
                                var position = _election?.Positions?.FirstOrDefault(p => p.Id == selection.Key);
                                if (position != null)
                                {
                                    <div class="mb-3">
                                        <strong class="text-primary">@position.Title:</strong>
                                        <ul class="list-unstyled ms-3">
                                            @foreach (var candidateId in selection.Value)
                                            {
                                                var candidate = position.Candidates?.FirstOrDefault(c => c.Id == candidateId);
                                                if (candidate != null)
                                                {
                                                    <li class="text-success">
                                                        <i class="bi bi-check-circle me-1"></i>
                                                        @candidate.FullName
                                                        @if (!string.IsNullOrEmpty(candidate.Class))
                                                        {
                                                            <small class="text-muted">(@candidate.Class)</small>
                                                        }
                                                    </li>
                                                }
                                            }
                                        </ul>
                                    </div>
                                }
                            }
                        </div>
                    </div>
                    
                    <div class="alert alert-info mt-3">
                        <i class="bi bi-info-circle me-2"></i>
                        By clicking "Yes, Submit My Votes", you confirm that these are your final choices for this election.
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="HideConfirmation">
                        <i class="bi bi-arrow-left me-1"></i>
                        Go Back to Review
                    </button>
                    <button type="button" class="btn btn-success" @onclick="ConfirmSubmitVotes" disabled="@_submitting">
                        @if (_submitting)
                        {
                            <span class="spinner-border spinner-border-sm me-2" role="status"></span>
                        }
                        <i class="bi bi-check-circle me-1"></i>
                        Yes, Submit My Votes
                    </button>
                </div>
            </div>
        </div>
    </div>
}

<style>
    .candidate-card {
        cursor: pointer;
        transition: all 0.2s ease;
    }

    .candidate-card:hover {
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
    }

    .position-section {
        border-left: 4px solid #0d6efd;
        padding-left: 20px;
    }

    .sticky-top {
        top: 20px;
    }
</style>
