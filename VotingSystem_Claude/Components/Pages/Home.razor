@page "/"
@using VotingSystem_Claude.Models
@using VotingSystem_Claude.Services
@using VotingSystem_Claude.Services.Interfaces
@using VotingSystem_Claude.Data
@inject IAuthService AuthService
@inject IElectionService ElectionService
@inject IVotingService VotingService
@inject NavigationManager NavigationManager
@inject IJSRuntime JSRuntime

@if (_redirecting)
{
    <div class="d-flex justify-content-center align-items-center" style="height: 100vh;">
        <div class="text-center">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Loading...</span>
            </div>
            <p class="mt-3">Redirecting...</p>
        </div>
    </div>
}
else
{
    <div class="d-flex flex-column justify-content-center align-items-center" style="min-height:calc( 100vh-60px); padding: 10px 0;">
        <div class="container-fluid">
            <div class="row justify-content-center">
                <div class="col-md-8 col-lg-6 text-center">
                    <!-- Smaller logo -->
                    <img src="images/school-logo1.png" alt="School Logo" class="mb-2" style="max-width: 100px;" />

                    <!-- Smaller headings -->
                    <h1 class="h2 text-primary-emphasis mb-2">Welcome to @SchoolName</h1>
                    <h2 class="h5 mb-4">Student Electoral Commission</h2>

                    @if (_loading)
                    {
                        <div class="spinner-border text-primary" role="status">
                            <span class="visually-hidden">Loading...</span>
                        </div>
                    }
                    else if (!string.IsNullOrEmpty(_errorMessage))
                    {
                        <div class="alert alert-danger text-center py-2">@_errorMessage</div>
                    }
                    else if (_voter != null)
                    {
                        NavigationManager.NavigateTo("/voter-dashboard");
                        return;
                    }
                    else if (_isAdmin)
                    {
                        NavigationManager.NavigateTo("/admin-dashboard");
                        return;
                    }
                    else
                    {
                        <div class="card">
                            <div class="card-header bg-primary text-white py-2">
                                <h3 class="mb-0 h5">Login</h3>
                            </div>
                            <div class="card-body py-3">
                                <ul class="nav nav-tabs mb-2" id="loginTabs" role="tablist">
                                    <li class="nav-item" role="presentation">
                                        <button class="nav-link @( _activeTab == "voter" ? "active" : "" )"
                                                @onclick='() => _activeTab = "voter"'
                                                type="button" role="tab">
                                            Voter
                                        </button>
                                    </li>
                                    <li class="nav-item" role="presentation">
                                        <button class="nav-link @( _activeTab == "admin" ? "active" : "" )"
                                                @onclick='() => _activeTab = "admin"'
                                                type="button" role="tab">
                                            Admin
                                        </button>
                                    </li>
                                </ul>

                                <div class="tab-content" id="loginTabsContent">
                                    @if (_activeTab == "voter")
                                    {
                                        <div class="tab-pane fade show active" id="voter-login" role="tabpanel">
                                            <form @onsubmit="LoginVoter" @onsubmit:preventDefault="true">
                                                <div class="form-group mb-2">
                                                    <label for="voterCode" class="form-label">Voter Code</label>
                                                    <input type="text" class="form-control" id="voterCode"
                                                           @bind="_voterCode" placeholder="Enter your voter code"
                                                           required />
                                                </div>
                                                <button type="submit" class="btn btn-primary w-100">Login as Voter</button>
                                            </form>
                                        </div>
                                    }
                                    else if (_activeTab == "admin")
                                    {
                                        <div class="tab-pane fade show active" id="admin-login" role="tabpanel">
                                            <form @onsubmit="LoginAdmin" @onsubmit:preventDefault="true">
                                                <div class="form-group mb-3">
                                                    <label for="adminUsername" class="form-label">Username</label>
                                                    <input type="text" class="form-control" id="adminUsername"
                                                           @bind="_adminUsername" placeholder="Enter admin username"
                                                           required />
                                                </div>
                                                <div class="form-group mb-3">
                                                    <label for="adminPassword" class="form-label">Password</label>
                                                    <input type="password" class="form-control" id="adminPassword"
                                                           @bind="_adminPassword" placeholder="Enter admin password"
                                                           required />
                                                </div>
                                                <button type="submit" class="btn btn-primary w-100">Login as Admin</button>
                                            </form>
                                        </div>
                                    }
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
}

@code {
    private string SchoolName = "Dabala Senior High Technical School"; // You can make this configurable
    private bool _loading = true;
    private Models.Voter _voter;
    private Election _activeElection;
    private bool _hasVoted;
    private bool _isAdmin;

    // Login fields
    private string _voterCode;
    private string _adminUsername;
    private string _adminPassword;
    private string _errorMessage;
    private string _activeTab = "voter";
    private bool _redirecting = false;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _loading = true;
            _errorMessage = string.Empty;

            _voter = await AuthService.GetAuthenticatedVoterAsync();
            _isAdmin = await AuthService.IsAdminAsync();

            if (_voter != null)
            {
                _redirecting = true;
                NavigationManager.NavigateTo("/voter-dashboard");
                return; // Exit early if voter is authenticated
            }
            else if (_isAdmin)
            {
                _redirecting = true;
                NavigationManager.NavigateTo("/admin-dashboard");
                return; // Exit early if admin is authenticated
            }

            // If not authenticated, proceed to load other page data if needed
            await LoadPageData();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Home.razor OnInitializedAsync Error: {ex.Message}\n{ex.StackTrace}");
            _errorMessage = "An unexpected error occurred during page initialization. Please try again.";
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task LoadPageData()
    {
        // This method will now only be called if the user is not authenticated as a voter or admin
        // Its purpose is to load election data for displaying on the home/login page if necessary
        _activeElection = await ElectionService.GetActiveElectionAsync();
        if (_activeElection != null)
        {
            _hasVoted = false;
        }
    }

    private async Task LoginVoter()
    {
        _loading = true;
        _errorMessage = string.Empty;
        var voter = await AuthService.AuthenticateVoterAsync(_voterCode);
        if (voter != null)
        {
            _redirecting = true;
            await LoadPageData();
            _voterCode = string.Empty;
            NavigationManager.NavigateTo("/voter-dashboard");
        }
        else
        {
            _errorMessage = "Invalid voter code.";
        }
        _loading = false;
    }

    private async Task LoginAdmin()
    {
        _loading = true;
        _errorMessage = string.Empty;
        var success = await AuthService.AuthenticateAdminAsync(_adminUsername, _adminPassword);
        if (success)
        {
            _redirecting = true;
            await LoadPageData();
            _adminUsername = string.Empty;
            _adminPassword = string.Empty;
            NavigationManager.NavigateTo("/admin-dashboard");
        }
        else
        {
            _errorMessage = "Invalid admin credentials.";
        }
        _loading = false;
    }

    private async Task Logout()
    {
        await AuthService.LogoutAsync();
        _redirecting = true;
        await LoadPageData();
        NavigationManager.NavigateTo("/");
    }

    private void StartVoting()
    {
        if (_activeElection != null)
        {
            NavigationManager.NavigateTo($"/election/{_activeElection.Id}/vote");
        }
    }

    private void ViewResults()
    {
        if (_activeElection != null)
        {
            NavigationManager.NavigateTo($"/election/{_activeElection.Id}/results");
        }
    }

    private void NavigateToElectionDashboard()
    {
        NavigationManager.NavigateTo("/admin/elections");
    }

    private void NavigateToVoterCodeManager()
    {
        NavigationManager.NavigateTo("/admin/voter-codes");
    }

    private void ViewAllResults()
    {
        NavigationManager.NavigateTo("/admin/all-results");
    }
}