@inject ThemeService ThemeService
@implements IDisposable

<div class="top-row ps-3 navbar navbar-dark">
    <div class="container-fluid">
        <a class="navbar-brand" href="">VotingSystem_Claude</a>
        <div class="d-flex align-items-center gap-2">
            <button class="theme-toggle-btn" @onclick="CycleTheme" title="@ThemeService.Label theme">
                <i class="@ThemeService.Icon theme-icon"></i>
            </button>
            <button title="Navigation menu" class="navbar-toggler" @onclick="ToggleNavMenu">
                <span class="navbar-toggler-icon"></span>
            </button>
        </div>
    </div>
</div>

<div class="@(collapseNavMenu ? "collapse" : null) navbar-collapse" @onclick="ToggleNavMenu">
    <nav class="flex-column">
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="" Match="NavLinkMatch.All">
                <span class="bi bi-house-door-fill-nav-menu" aria-hidden="true"></span> Home
            </NavLink>
        </div>
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="admin-dashboard">
                <span class="bi bi-speedometer2" aria-hidden="true"></span> Admin Dashboard
            </NavLink>
        </div>
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="voters">
                <span class="bi bi-people-fill" aria-hidden="true"></span> Voters
            </NavLink>
        </div>
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="votercodes">
                <span class="bi bi-key-fill" aria-hidden="true"></span> Voter Codes
            </NavLink>
        </div>
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="elections">
                <span class="bi bi-calendar-event" aria-hidden="true"></span> Elections
            </NavLink>
        </div>
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="results">
                <span class="bi bi-bar-chart-line-fill" aria-hidden="true"></span> Results
            </NavLink>
        </div>
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="students">
                <span class="bi bi-mortarboard-fill" aria-hidden="true"></span> Students
            </NavLink>
        </div>
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="/register">
                <span class="bi bi-person-plus-fill" aria-hidden="true"></span> Register
            </NavLink>
        </div>
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="/login">
                <span class="bi bi-box-arrow-in-right" aria-hidden="true"></span> Login
            </NavLink>
        </div>
    </nav>
</div>

@code {
    private bool collapseNavMenu = true;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            ThemeService.OnChanged += StateHasChanged;
            await ThemeService.InitializeAsync();
            StateHasChanged();
        }
    }

    private async Task CycleTheme()
    {
        await ThemeService.SetAsync(ThemeService.Next());
    }

    private void ToggleNavMenu()
    {
        collapseNavMenu = !collapseNavMenu;
    }

    public void Dispose()
    {
        ThemeService.OnChanged -= StateHasChanged;
    }
}
