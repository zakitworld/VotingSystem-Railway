{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    },
    "ApplicationInsights": {
      "LogLevel": {
        "Default": "Information"
      }
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=ZAK-I-T-WORLD\\SQLEXPRESS;Initial Catalog=Blazor_VotingSystem_DB;Integrated Security=True;Trust Server Certificate=True;MultipleActiveResultSets=True"
  },
  "Security": {
    "SessionTimeoutMinutes": 30,
    "RequireHttps": true,
    "EnableRateLimiting": true,
    "RateLimitRequestsPerMinute": 100,
    "EnableTwoFactorAuth": true,
    "PasswordPolicy": {
      "RequireDigit": true,
      "RequireLowercase": true,
      "RequireUppercase": true,
      "RequireNonAlphanumeric": true,
      "RequiredLength": 12
    },
    "AllowedIpAddresses": [
      "127.0.0.1",
      "::1"
    ],
    "BlockedIpAddresses": [],
    "AuditLogging": {
      "Enabled": true,
      "RetentionDays": 90,
      "LogLevel": "Information"
    }
  },
  "Caching": {
    "EnableResponseCaching": true,
    "EnableMemoryCache": true,
    "CacheDurationMinutes": 60
  },
  "HealthChecks": {
    "EnableHealthChecks": true,
    "HealthCheckIntervalSeconds": 30
  },
  "Analytics": {
    "EnableRealTimeStats": true,
    "EnableVoterAnalytics": true,
    "EnableExport": true,
    "ExportFormats": ["CSV", "PDF", "Excel"]
  }
}
